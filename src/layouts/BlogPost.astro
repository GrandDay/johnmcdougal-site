---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { id: string };

const { title, description, pubDate, updatedDate, heroImage, tags, id } = Astro.props;

const allPosts = await getCollection('blog');
const related = allPosts
.filter((p) => p.id !== id && p.data.tags.some((t) => tags.includes(t)))
.sort((a, b) => {
const aShared = a.data.tags.filter((t) => tags.includes(t)).length;
const bShared = b.data.tags.filter((t) => tags.includes(t)).length;
if (bShared !== aShared) return bShared - aShared;
return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
})
.slice(0, 3);
---

<html lang="en">
<head>
<BaseHead title={title} description={description} pubDate={pubDate} />
<style>
main {
width: calc(100% - 2em);
max-width: 100%;
margin: 0;
}
.hero-image { width: 100%; }
.hero-image img {
display: block;
margin: 0 auto;
border-radius: 12px;
box-shadow: var(--shadow);
}
.prose {
width: 720px;
max-width: calc(100% - 2em);
margin: auto;
padding: 1em 1em 3em;
color: var(--text);
}
.title {
margin-bottom: 1.5em;
padding: 1em 0;
border-bottom: 1px solid rgba(128,128,128,0.15);
}
.title h1 { margin: 0 0 0.35em; line-height: 1.2; }
.date { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 0.25em; }
.last-updated-on { font-style: italic; }

/* Prose content */
.prose :global(p) { line-height: 1.75; margin: 0 0 1.1em; }
.prose :global(a) { color: var(--accent); }
.prose :global(a:hover) { text-decoration: underline; }
.prose :global(h2) {
font-size: 1.35rem;
margin: 2em 0 0.75em;
padding-bottom: 0.35em;
border-bottom: 1px solid rgba(128,128,128,0.12);
}
.prose :global(h3) { font-size: 1.1rem; margin: 1.5em 0 0.5em; }
.prose :global(ul), .prose :global(ol) {
padding-left: 1.5em;
margin: 0 0 1.1em;
line-height: 1.75;
}
.prose :global(li) { margin-bottom: 0.3em; }
.prose :global(code) {
font-size: 0.875em;
background: var(--bg-secondary);
padding: 0.15em 0.4em;
border-radius: 4px;
}
.prose :global(pre) {
background: var(--bg-secondary);
padding: 1.25em;
border-radius: 8px;
overflow-x: auto;
margin: 0 0 1.5em;
}
.prose :global(pre code) { background: none; padding: 0; font-size: 0.875em; }
.prose :global(blockquote) {
border-left: 3px solid var(--accent);
padding: 0.25em 0 0.25em 1em;
margin: 1.5em 0;
color: var(--text-muted);
font-style: italic;
}
.prose :global(hr) {
border: none;
border-top: 1px solid rgba(128,128,128,0.15);
margin: 2em 0;
}

/* Post tags */
.post-tags {
display: flex;
flex-wrap: wrap;
gap: 0.4em;
margin: 2em 0 0;
padding-top: 1.5em;
border-top: 1px solid rgba(128,128,128,0.12);
}

/* Related reading */
.related {
margin-top: 2.5em;
padding-top: 1.5em;
border-top: 1px solid rgba(128,128,128,0.15);
}
.related-label {
font-size: 0.7rem;
font-weight: 700;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(--accent);
margin: 0 0 0.9em;
}
.related-list {
list-style: none;
padding: 0;
margin: 0;
display: flex;
flex-direction: column;
gap: 0.1em;
}
.related-link {
display: flex;
justify-content: space-between;
align-items: baseline;
gap: 1em;
padding: 0.6em 0;
border-bottom: 1px solid rgba(128,128,128,0.1);
text-decoration: none;
color: var(--text);
}
.related-link:last-child { border-bottom: none; }
.related-link:hover .related-title { color: var(--accent); }
.related-title { transition: color 0.15s; font-size: 0.95rem; }
.related-shared-tags {
display: flex;
gap: 0.3em;
flex-wrap: wrap;
flex-shrink: 0;
}
.related-tag {
font-size: 0.7rem;
color: var(--text-muted);
background: var(--bg-secondary);
padding: 0.1em 0.45em;
border-radius: 999px;
}
</style>
</head>

<body>
<Header />
<main>
<article>
<div class="hero-image">
{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
</div>
<div class="prose">
<div class="title">
<div class="date">
<FormattedDate date={pubDate} />
{updatedDate && (
<div class="last-updated-on">
Last updated on <FormattedDate date={updatedDate} />
</div>
)}
</div>
<h1>{title}</h1>
</div>
<slot />
{tags.length > 0 && (
<div class="post-tags">
{tags.map((tag) => (
<a href={`/tags/${tag}`} class="tag">{tag}</a>
))}
</div>
)}
{related.length > 0 && (
<div class="related">
<p class="related-label">Related reading</p>
<ul class="related-list">
{related.map((post) => (
<li>
<a href={`/blog/${post.id}`} class="related-link">
<span class="related-title">{post.data.title}</span>
<span class="related-shared-tags">
{post.data.tags
.filter((t) => tags.includes(t))
.map((t) => (
<span class="related-tag">{t}</span>
))}
</span>
</a>
</li>
))}
</ul>
</div>
)}
</div>
</article>
</main>
<Footer />
</body>
</html>