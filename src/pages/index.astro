---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';

const recentPosts = (await getCollection('blog'))
.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
.slice(0, 3);

const featuredProjects = (await getCollection('projects'))
.filter((p) => p.data.status === 'active' || p.data.status === 'wip')
.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
.slice(0, 3);
---

<!doctype html>
<html lang="en">
<head>
<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
<style>
.hero {
padding: 4rem 0 2.5rem;
border-bottom: 1px solid var(--color-border, rgba(128,128,128,0.2));
margin-bottom: 3rem;
}
.hero-name {
font-size: clamp(2rem, 5vw, 3rem);
font-weight: 700;
margin: 0 0 0.2rem;
line-height: 1.1;
}
.hero-tagline {
font-size: clamp(1.1rem, 2.5vw, 1.5rem);
color: rgb(var(--accent));
font-weight: 600;
margin: 0 0 0.9rem;
}
.hero-description {
font-size: 1.05rem;
color: rgb(var(--gray));
max-width: 55ch;
margin: 0 0 1.5rem;
line-height: 1.6;
}
.hero-links {
display: flex;
gap: 0.75rem;
flex-wrap: wrap;
}
.hero-links a {
color: rgb(var(--accent));
text-decoration: none;
font-weight: 500;
font-size: 0.95rem;
border: 1px solid rgb(var(--accent));
padding: 0.35rem 0.85rem;
border-radius: 6px;
transition: background 0.15s, color 0.15s;
}
.hero-links a:hover {
background: rgb(var(--accent));
color: #000;
}
.section {
margin-bottom: 3.5rem;
}
.section-header {
display: flex;
align-items: baseline;
justify-content: space-between;
margin-bottom: 1.1rem;
padding-bottom: 0.5rem;
border-bottom: 1px solid rgba(128,128,128,0.15);
}
.section-label {
font-size: 0.75rem;
font-weight: 700;
letter-spacing: 0.1em;
text-transform: uppercase;
color: rgb(var(--gray));
margin: 0;
}
.section-header a {
font-size: 0.85rem;
color: rgb(var(--accent));
text-decoration: none;
}
.section-header a:hover { text-decoration: underline; }
.post-list {
list-style: none;
margin: 0;
padding: 0;
display: flex;
flex-direction: column;
gap: 0.1rem;
}
.post-item a {
display: flex;
justify-content: space-between;
align-items: baseline;
gap: 1rem;
text-decoration: none;
color: rgb(var(--gray-dark));
padding: 0.6rem 0;
transition: color 0.15s;
}
.post-item a:hover { color: rgb(var(--accent)); }
.post-title { font-weight: 500; }
.post-date {
font-size: 0.82rem;
color: rgb(var(--gray));
white-space: nowrap;
flex-shrink: 0;
}
.empty-state {
color: rgb(var(--gray));
font-size: 0.95rem;
padding: 0.5rem 0;
}
.project-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
gap: 1rem;
}
.project-card {
border: 1px solid rgba(128,128,128,0.2);
border-radius: 8px;
padding: 1.1rem 1.25rem;
text-decoration: none;
color: rgb(var(--gray-dark));
display: block;
transition: border-color 0.15s;
}
.project-card:hover { border-color: rgb(var(--accent)); }
.project-card-status {
font-size: 0.68rem;
font-weight: 700;
text-transform: uppercase;
letter-spacing: 0.06em;
margin-bottom: 0.4rem;
}
.status-active { color: #22c55e; }
.status-wip { color: #f59e0b; }
.project-card-title {
font-weight: 600;
margin: 0 0 0.35rem;
font-size: 0.975rem;
}
.project-card-desc {
font-size: 0.85rem;
color: rgb(var(--gray));
margin: 0;
line-height: 1.5;
}
</style>
</head>
<body>
<Header />
<main>
<section class="hero">
<h1 class="hero-name">{SITE_AUTHOR}</h1>
<p class="hero-tagline">{SITE_TAGLINE}</p>
<p class="hero-description">{SITE_DESCRIPTION}</p>
<nav class="hero-links">
<a href="/about">About me</a>
<a href="/blog">Writing</a>
<a href="/projects">Projects</a>
</nav>
</section>

<section class="section">
<div class="section-header">
<p class="section-label">Recent writing</p>
{recentPosts.length > 0 && <a href="/blog">All posts &rarr;</a>}
</div>
{recentPosts.length > 0 ? (
<ul class="post-list">
{recentPosts.map((post) => (
<li class="post-item">
<a href={`/blog/${post.id}/`}>
<span class="post-title">{post.data.title}</span>
<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
</a>
</li>
))}
</ul>
) : (
<p class="empty-state">Nothing published yet — something is always in the draft pile. Check back soon.</p>
)}
</section>

{featuredProjects.length > 0 && (
<section class="section">
<div class="section-header">
<p class="section-label">Projects</p>
<a href="/projects">All projects &rarr;</a>
</div>
<div class="project-grid">
{featuredProjects.map((project) => (
<a class="project-card" href={`/projects/${project.id}/`}>
<div class={`project-card-status status-${project.data.status}`}>
{project.data.status === 'wip' ? 'In progress' : project.data.status}
</div>
<p class="project-card-title">{project.data.title}</p>
<p class="project-card-desc">{project.data.description}</p>
</a>
))}
</div>
</section>
)}
</main>
<Footer />
</body>
</html>
