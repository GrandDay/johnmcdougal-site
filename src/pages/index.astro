---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPost = allPosts[0];

const allProjects = await getCollection('projects');
const latestProject = [...allProjects].sort((a, b) => {
  const aDate = (a.data.updatedDate ?? a.data.pubDate).valueOf();
  const bDate = (b.data.updatedDate ?? b.data.pubDate).valueOf();
  return bDate - aDate;
})[0];
const activeProjectCount = allProjects.filter(
  (p) => p.data.status === 'active' || p.data.status === 'wip'
).length;

const tagMap = new Map<string, number>();
[...allPosts, ...allProjects].forEach((item) => {
  item.data.tags.forEach((tag) => {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  });
});
const allTags = [...tagMap.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<!doctype html>
<html lang="en">
<head>
<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
<style>
.hero {
  padding: 4rem 0 2.5rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2rem;
}
.hero-name {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 700;
  margin: 0 0 0.2rem;
  line-height: 1.1;
}
.hero-tagline {
  font-size: clamp(1.1rem, 2.5vw, 1.5rem);
  color: var(--accent);
  font-weight: 600;
  margin: 0 0 0.6rem;
}
.hero-description {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 55ch;
  margin: 0;
  line-height: 1.6;
}

/* Tag bar */
.tag-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5em;
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border);
}
@media (max-width: 720px) {
  .tag-bar {
    flex-wrap: nowrap;
    overflow-x: auto;
    padding-bottom: 1rem;
    scrollbar-width: none;
  }
  .tag-bar::-webkit-scrollbar { display: none; }
  .tag-bar .tag { flex-shrink: 0; }
}

/* Portal grid */
.portal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-bottom: 3rem;
}
@media (max-width: 720px) {
  .portal-grid { grid-template-columns: 1fr; }
}
.portal-tile {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.4rem 1.5rem;
  text-decoration: none;
  color: var(--text);
  background: var(--bg-secondary);
  transition: border-color 0.15s, background 0.15s;
}
.portal-tile:hover {
  border-color: var(--accent);
  background: var(--bg);
}
.portal-label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.35rem;
}
.portal-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.3rem;
  transition: color 0.15s;
}
.portal-tile:hover .portal-title { color: var(--accent); }
.portal-subtitle {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.5;
  flex: 1;
}
.portal-divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 1rem 0 0.75rem;
}
.portal-recency-label {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
  display: block;
  margin-bottom: 0.2rem;
}
.portal-recency-title {
  font-size: 0.875rem;
  color: var(--text);
  display: block;
  line-height: 1.4;
  margin-bottom: 0.15rem;
}
.portal-recency-date {
  font-size: 0.78rem;
  color: var(--text-muted);
  display: block;
}
.portal-cta {
  font-size: 0.82rem;
  color: var(--accent);
  margin-top: 1rem;
  display: block;
}
</style>
</head>
<body>
<Header />
<main>
  <section class="hero">
    <h1 class="hero-name">{SITE_AUTHOR}</h1>
    <p class="hero-tagline">{SITE_TAGLINE}</p>
    <p class="hero-description">{SITE_DESCRIPTION}</p>
  </section>

  {allTags.length > 0 && (
    <div class="tag-bar">
      {allTags.map(([tag]) => (
        <a href={`/tags/${tag}`} class="tag">{tag}</a>
      ))}
    </div>
  )}

  <div class="portal-grid">
    <a href="/blog" class="portal-tile">
      <div class="portal-label">Writing</div>
      <div class="portal-title">{allPosts.length} post{allPosts.length !== 1 ? 's' : ''}</div>
      <div class="portal-subtitle">Essays, walkthroughs, and thinking out loud.</div>
      {latestPost && (
        <>
          <hr class="portal-divider" />
          <span class="portal-recency-label">Latest</span>
          <span class="portal-recency-title">{latestPost.data.title}</span>
          <span class="portal-recency-date"><FormattedDate date={latestPost.data.pubDate} /></span>
        </>
      )}
      <span class="portal-cta">Browse all &rarr;</span>
    </a>

    <a href="/projects" class="portal-tile">
      <div class="portal-label">Projects</div>
      <div class="portal-title">{activeProjectCount} active</div>
      <div class="portal-subtitle">Things in progress, things documented, things half-broken.</div>
      {latestProject && (
        <>
          <hr class="portal-divider" />
          <span class="portal-recency-label">Last updated</span>
          <span class="portal-recency-title">{latestProject.data.title}</span>
          <span class="portal-recency-date"><FormattedDate date={latestProject.data.updatedDate ?? latestProject.data.pubDate} /></span>
        </>
      )}
      <span class="portal-cta">Browse all &rarr;</span>
    </a>

    <a href="/about" class="portal-tile">
      <div class="portal-label">About</div>
      <div class="portal-title">{SITE_AUTHOR}</div>
      <div class="portal-subtitle">Sacramento-based IT consultant, homelabber, and chronic pattern-finder.</div>
      <span class="portal-cta">Read more &rarr;</span>
    </a>
  </div>
</main>
<Footer />
</body>
</html>
