---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="404 -- Page Not Found | John McDougal"
      description="This page doesn't exist. Dead link, path not built yet, or something moved. You can find your way from here."
    />
    <style>
      .not-found {
        padding: 6rem 0 4rem;
        text-align: center;
      }
      .code {
        font-size: clamp(5rem, 18vw, 9rem);
        font-weight: 700;
        color: rgb(var(--accent));
        line-height: 1;
        margin: 0 0 0.2em;
        font-variant-numeric: tabular-nums;
      }
      .message {
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--text);
        margin: 0 0 0.6em;
      }
      .subtext {
        font-size: 0.97rem;
        color: var(--text-muted);
        max-width: 44ch;
        margin: 0 auto 2.5em;
        line-height: 1.6;
      }
      .nav {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      .nav a {
        color: rgb(var(--accent));
        text-decoration: none;
        font-weight: 500;
        border: 1px solid rgb(var(--accent));
        padding: 0.35rem 0.9rem;
        border-radius: 6px;
        font-size: 0.95rem;
        transition: background 0.15s, color 0.15s;
      }
      .nav a:hover {
        background: rgb(var(--accent));
        color: #000;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="not-found">
        <p class="code">404</p>
        <p class="message">Nothing here.</p>
        <p class="subtext">
          Dead link, path I haven't built yet, or something moved. Either way -- you can find your way from here.
        </p>
        <nav class="nav">
          <a href="/">Home</a>
          <a href="/blog">Writing</a>
          <a href="/projects">Projects</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </main>
    <Footer />
  </body>
</html>
