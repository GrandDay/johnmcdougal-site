---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const blogPosts = await getCollection('blog');
const projects = await getCollection('projects');

// Collect all tags with counts
const tagMap = new Map<string, number>();
[...blogPosts, ...projects].forEach((item) => {
	item.data.tags.forEach((tag: string) => {
		tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
	});
});

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Tags</h1>
			<p class="lead">Browse everything by topic — blog posts and projects together.</p>

			{tags.length === 0 && (
				<p style="color: var(--text-muted)">No tags yet. Coming soon.</p>
			)}

			<div class="tag-cloud">
				{tags.map(([tag, count]) => (
					<a href={`/tags/${tag}`} class="tag-item">
						<span class="tag">{tag}</span>
						<span class="count">{count}</span>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 { margin-bottom: 0.25em; }
	.lead {
		color: var(--text-muted);
		margin-bottom: 2em;
	}
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75em;
	}
	.tag-item {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		text-decoration: none;
	}
	.count {
		font-size: 0.7em;
		color: var(--text-muted);
	}
</style>
