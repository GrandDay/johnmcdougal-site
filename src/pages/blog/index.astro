---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tagMap = new Map<string, number>();
posts.forEach((post) => {
	post.data.tags.forEach((tag) => {
		tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
	});
});
const allTags = [...tagMap.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Writing</h1>
			<p class="lead">Essays, walkthroughs, and thinking out loud. Process over polish.</p>

			{allTags.length > 0 && (
				<div class="tag-bar">
					{allTags.map(([tag]) => (
						<a href={`/tags/${tag}`} class="tag">{tag}</a>
					))}
				</div>
			)}

			{posts.length === 0 && (
				<p style="color: var(--text-muted)">Nothing published yet — something is always in the draft pile. Check back soon.</p>
			)}

			<ul class="post-list">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="post-card">
							<div class="post-header">
								<h2>{post.data.title}</h2>
								{post.data.series && post.data.seriesPart && (
									<span class="series-badge">Part {post.data.seriesPart}</span>
								)}
							</div>
							{post.data.description && (
								<p class="post-desc">{post.data.description}</p>
							)}
							<div class="post-meta">
								<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								{post.data.tags.length > 0 && (
									<div class="post-tags">
										{post.data.tags.map((tag) => (
											<span class="tag-label">{tag}</span>
										))}
									</div>
								)}
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 { margin-bottom: 0.25em; }
	.lead {
		color: var(--text-muted);
		margin-bottom: 1.5em;
		font-size: 1.05em;
	}
	.tag-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin-bottom: 2em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid var(--border);
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1px;
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
	}
	.post-card {
		display: block;
		padding: 1.25em 1.5em;
		background: var(--bg-secondary);
		text-decoration: none;
		color: var(--text);
		transition: background 0.15s ease;
	}
	.post-card:hover {
		background: var(--bg);
	}
	.post-card:hover h2 {
		color: var(--accent);
	}
	.post-header {
		display: flex;
		align-items: center;
		gap: 0.75em;
		margin-bottom: 0.25em;
	}
	h2 {
		font-size: 1.1em;
		margin: 0;
		transition: color 0.15s ease;
	}
	.post-desc {
		margin: 0 0 0.6em;
		color: var(--text-muted);
		font-size: 0.95em;
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 1em;
		flex-wrap: wrap;
	}
	.date {
		font-size: 0.8em;
		color: var(--text-muted);
	}
	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}
	.tag-label {
		font-size: 0.7em;
		color: var(--text-muted);
		background: var(--bg);
		padding: 0.15em 0.5em;
		border-radius: 999px;
		border: 1px solid var(--border);
	}
</style>
