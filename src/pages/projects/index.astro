---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const statusLabel = { active: 'Active', wip: 'WIP', archived: 'Archived' };
const statusColor = { active: 'var(--accent)', wip: '#f59e0b', archived: 'var(--text-muted)' };
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<p class="lead">
				Things I'm building, experimenting with, or have documented along the way.
				Process over polish — the WIPs are as much the point as the finished ones.
			</p>

			{projects.length === 0 && (
				<p style="color: var(--text-muted)">Projects coming soon. Watch this space.</p>
			)}

			<ul class="project-list">
				{projects.map((project) => (
					<li>
						<a href={`/projects/${project.id}`} class="project-card">
							<div class="project-header">
								<h2>{project.data.title}</h2>
								<span
									class="status-badge"
									style={`color: ${statusColor[project.data.status]}; border-color: ${statusColor[project.data.status]};`}
								>
									{statusLabel[project.data.status]}
								</span>
							</div>
							<p>{project.data.description}</p>
							<div class="project-meta">
								<span class="date"><FormattedDate date={project.data.pubDate} /></span>
								<div class="tags">
									{project.data.tags.map((tag) => (
										<a href={`/tags/${tag}`} class="tag">{tag}</a>
									))}
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 { margin-bottom: 0.25em; }
	.lead {
		color: var(--text-muted);
		margin-bottom: 2em;
		font-size: 1.05em;
	}
	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1px;
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
	}
	.project-card {
		display: block;
		padding: 1.25em 1.5em;
		background: var(--bg-secondary);
		text-decoration: none;
		color: var(--text);
		transition: background 0.15s ease;
	}
	.project-card:hover {
		background: var(--bg);
	}
	.project-card:hover h2 {
		color: var(--accent);
	}
	.project-header {
		display: flex;
		align-items: center;
		gap: 0.75em;
		margin-bottom: 0.25em;
	}
	h2 {
		font-size: 1.1em;
		margin: 0;
		transition: color 0.15s ease;
	}
	.status-badge {
		font-size: 0.7em;
		font-weight: 700;
		padding: 0.15em 0.5em;
		border: 1px solid;
		border-radius: 999px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	p {
		margin: 0 0 0.75em;
		color: var(--text-muted);
		font-size: 0.95em;
	}
	.project-meta {
		display: flex;
		align-items: center;
		gap: 1em;
	}
	.date {
		font-size: 0.8em;
		color: var(--text-muted);
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}
</style>
